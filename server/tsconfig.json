{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "../",
    "baseUrl": "../",
    "types": ["node"],
    "paths": {
      "@server/*": ["server/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["../server/**/*", "../lib/**/*"]
}
